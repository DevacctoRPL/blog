<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Blog' %></title>
    <link rel="icon" type="image/png" href="/images/favicon.png">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="retro-body">
    <header class="retro-site-header">
        <div class="container retro-header-inner">
            <a href="<%= BASE_PATH %>" class="retro-logo">
                <img src="/images/favicon.png" alt="Logo RPL" class="retro-logo-img">
                <span>Blog Portal</span>
            </a>
            <button class="hamburger retro-hamburger" id="hamburger" aria-label="Toggle menu" aria-controls="main-nav" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
            <nav id="main-nav" class="retro-top-nav" aria-label="Main navigation">
                <ul>
                    <li><a href="<%= BASE_PATH %>">Home</a></li>
                    <li><a href="<%= BASE_PATH %>/posts">All Posts</a></li>
                    <li><a href="<%= BASE_PATH %>/categories">Categories</a></li>
                </ul>
            </nav>
        </div>
    </header>
    <div class="mobile-nav-overlay" id="mobile-nav-overlay"></div>
    <script>
        (function(){
            var h=document.getElementById('hamburger'),n=document.getElementById('main-nav'),o=document.getElementById('mobile-nav-overlay'),b=document.body;
            if(!h||!n||!o)return;
            function toggleNav(){var isOpen=n.classList.toggle('open');h.classList.toggle('active',isOpen);h.setAttribute('aria-expanded',String(isOpen));o.classList.toggle('active',isOpen);b.classList.toggle('nav-open',isOpen);}
            h.addEventListener('click',toggleNav);
            o.addEventListener('click',toggleNav);
            window.addEventListener('resize',function(){if(window.innerWidth>992){n.classList.remove('open');h.classList.remove('active');h.setAttribute('aria-expanded','false');o.classList.remove('active');b.classList.remove('nav-open');}});
        })();
    </script>
    <main class="retro-main">
