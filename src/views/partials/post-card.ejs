<%
var _readMin = Math.ceil(((post.content || '').split(/\s+/).length) / 200) || 1;
var _excerpt = (post.content || '').replace(/[#*`]/g, '').substring(0, 140);
var thumbUrl = post.thumbnail || post.pathID;
if (thumbUrl && !thumbUrl.startsWith('http') && !thumbUrl.startsWith('/')) thumbUrl = BASE_PATH + '/' + thumbUrl;
%>
<article class="retro-post-item">
    <a href="<%= BASE_PATH %>/posts/<%= post.slug %>" class="retro-post-thumb" aria-label="<%= post.title %>">
        <% if (thumbUrl) { %><img src="<%= thumbUrl %>" alt="<%= post.title %>"><% } else { %><span>No Image</span><% } %>
    </a>
    <div class="retro-post-copy">
        <h3><a href="<%= BASE_PATH %>/posts/<%= post.slug %>"><%= post.title %></a></h3>
        <p class="retro-post-meta">
            <% if (post.Category) { %><a href="<%= BASE_PATH %>/posts/category/<%= post.Category.slug %>"><%= post.Category.name %></a> | <% } %>
            Oleh <%= post.User ? post.User.username : 'Admin' %> |
            <%= post.createdAt ? new Date(post.createdAt).toLocaleDateString('id-ID', { month: 'short', day: 'numeric', year: 'numeric' }) : '-' %> |
            <%= _readMin %> menit baca
        </p>
        <p class="retro-post-excerpt"><%= _excerpt %>…</p>
        <a href="<%= BASE_PATH %>/posts/<%= post.slug %>" class="retro-readmore">Baca selengkapnya »</a>
    </div>
</article>
