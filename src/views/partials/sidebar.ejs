<aside class="retro-sidebar">
    <section class="retro-panel">
        <h3 class="retro-panel-title">📁 Kategori</h3>
        <div class="retro-panel-body">
            <ul class="retro-link-list">
                <li><a href="<%= BASE_PATH %>/categories">Semua Kategori</a></li>
                <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                    <% categories.forEach(cat => { %>
                        <li><a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>"><%= cat.name %></a></li>
                    <% }) %>
                <% } else { %>
                    <li class="retro-muted">Belum ada kategori</li>
                <% } %>
            </ul>
        </div>
    </section>
</aside>
