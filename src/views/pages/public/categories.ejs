<%- include('../../partials/header', { title: 'Kategori - Blog' }) %>
<section class="retro-page-banner"><div class="container"><h1>Direktori Kategori</h1><p>Telusuri artikel berdasarkan topik seperti portal web klasik.</p></div></section>
<div class="container retro-two-column">
    <section class="retro-panel retro-full-span">
        <h2 class="retro-panel-title">📚 Semua Kategori</h2>
        <div class="retro-panel-body retro-directory-grid">
            <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                <% categories.forEach((cat, idx) => { %>
                    <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>" class="retro-directory-item"><span class="retro-index"><%= String(idx + 1).padStart(2, '0') %></span><%= cat.name %></a>
                <% }) %>
            <% } else { %><p class="retro-empty">Belum ada kategori.</p><% } %>
        </div>
    </section>
</div>
<%- include('../../partials/footer') %>
