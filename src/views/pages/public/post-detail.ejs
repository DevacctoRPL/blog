<%- include('../../partials/header', { title: post.title + ' - Blog' }) %>
<% var catName = post.Category ? post.Category.name : 'General'; %>
<section class="retro-page-banner"><div class="container"><h1><%= post.title %></h1><p>Oleh <%= post.User ? post.User.username : 'Admin' %> | <%= post.createdAt ? new Date(post.createdAt).toLocaleDateString('id-ID', { month: 'long', day: 'numeric', year: 'numeric' }) : '-' %> | <%= readingTime || 1 %> menit baca</p></div></section>
<div class="container retro-article-layout">
    <aside class="retro-sidebar">
        <section class="retro-panel"><h3 class="retro-panel-title">📌 Daftar Isi</h3><div class="retro-panel-body"><ul class="retro-link-list toc-list" id="toc"><% if (toc && toc.length > 0) { toc.forEach((item, index) => { %><li class="toc-item <%= index === 0 ? 'active' : '' %>"><a href="#<%= item.id %>"><%= item.text %></a></li><% }); } else { %><li class="retro-muted">Tidak ada daftar isi.</li><% } %></ul></div></section>
    </aside>
    <article class="retro-panel retro-article-panel">
        <h2 class="retro-panel-title">📄 <%= post.title %></h2>
        <div class="retro-panel-body">
            <% if (post.Category) { %><p class="retro-status-line">Kategori: <a href="<%= BASE_PATH %>/posts/category/<%= post.Category.slug %>"><%= post.Category.name %></a></p><% } %>
            <div class="markdown-content retro-markdown"><%- contentHtml %></div>
        </div>
    </article>
    <aside class="retro-utility-column">
        <section class="retro-panel" x-data="{ liked:false,count:0,loading:false,showLoginModal:false,init(){fetch('<%= BASE_PATH %>/api/likes/<%= post.id %>/count').then(r=>r.json()).then(d=>{this.count=d.count}).catch(()=>{});fetch('<%= BASE_PATH %>/api/likes/<%= post.id %>/check').then(r=>r.ok?r.json():{liked:false}).then(d=>{this.liked=d.liked}).catch(()=>{});},toggle(){if(this.loading)return;this.loading=true;fetch('<%= BASE_PATH %>/api/likes/<%= post.id %>/toggle',{method:'POST'}).then(r=>r.ok?r.json():Promise.reject()).then(d=>{this.liked=d.liked;this.count=d.count}).catch(()=>{this.showLoginModal=true}).finally(()=>{this.loading=false})}}">
            <h3 class="retro-panel-title">❤️ Suka</h3><div class="retro-panel-body"><button class="retro-button" @click="toggle()" :disabled="loading"><span x-text="liked ? 'Disukai' : 'Suka'"></span> (<span x-text="count"></span>)</button><p x-show="showLoginModal" class="retro-alert">Login untuk memberikan suka. <a href="<%= BASE_PATH %>/auth/google">Login Google</a></p></div>
        </section>
        <section class="retro-panel"><h3 class="retro-panel-title">🏷️ Kategori</h3><div class="retro-panel-body retro-badge-list"><% var displayCats=[]; if (post.Category) displayCats.push(post.Category); if (typeof categories !== 'undefined' && categories && categories.length > 0) categories.forEach(cat => { if (!post.Category || cat.id !== post.Category.id) displayCats.push(cat); }); displayCats=displayCats.slice(0,6); %><% if (displayCats.length > 0) { displayCats.forEach(cat => { %><a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>"><%= cat.name %></a><% }) } else { %><span class="retro-muted">Belum ada kategori.</span><% } %></div></section>
    </aside>
</div>
<% if (typeof relatedPosts !== 'undefined' && relatedPosts && relatedPosts.length > 0) { %><div class="container"><section class="retro-panel"><h3 class="retro-panel-title">🔗 Postingan Relevan</h3><div class="retro-panel-body retro-post-list"><% relatedPosts.slice(0, 3).forEach(post => { %><%- include('../../partials/post-card', { post, BASE_PATH, catColor }) %><% }) %></div></section></div><% } %>
<script>document.addEventListener('DOMContentLoaded',()=>{if(window.hljs)hljs.highlightAll();document.querySelectorAll('.toc-item a').forEach(anchor=>{anchor.addEventListener('click',e=>{e.preventDefault();const id=anchor.getAttribute('href').slice(1);const el=document.getElementById(id);if(!el)return;window.scrollTo({top:el.offsetTop-90,behavior:'smooth'});history.pushState(null,null,'#'+id);});});fetch('<%= BASE_PATH %>/api/popularity/<%= post.id %>/view',{method:'PATCH'}).catch(err=>console.error('Error logging view:',err));});</script>
<%- include('../../partials/footer') %>
