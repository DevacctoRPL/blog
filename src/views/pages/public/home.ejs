<%- include('../../partials/header', { title: typeof title !== 'undefined' ? title : 'Blog - Portal Artikel' }) %>

<section class="retro-page-banner">
    <div class="container">
        <h1><%= (typeof isLandingPage !== 'undefined' && isLandingPage) ? 'Insight & Update Rekayasa Perangkat Lunak' : (typeof title !== 'undefined' ? title : 'Semua Artikel') %></h1>
        <p><%= (typeof q !== 'undefined' && q) ? ('Hasil pencarian untuk "' + q + '"') : 'Portal blog padat informasi: artikel, kategori, dan tulisan populer.' %></p>
    </div>
</section>

<div class="container retro-portal-layout">
    <%- include('../../partials/sidebar', { categories: (typeof categories !== 'undefined' ? categories : []), BASE_PATH }) %>

    <section class="retro-content-column">
        <% if ((typeof isLandingPage !== 'undefined' && isLandingPage) && posts && posts.length > 0) { var featuredPost = posts[0]; var featThumbUrl = featuredPost.thumbnail || featuredPost.pathID; if (featThumbUrl && !featThumbUrl.startsWith('http') && !featThumbUrl.startsWith('/')) featThumbUrl = BASE_PATH + '/' + featThumbUrl; %>
            <article class="retro-panel retro-featured-post">
                <h2 class="retro-panel-title">⭐ Artikel Pilihan</h2>
                <div class="retro-panel-body retro-featured-body">
                    <% if (featThumbUrl) { %><img src="<%= featThumbUrl %>" alt="<%= featuredPost.title %>" class="retro-featured-img"><% } %>
                    <div>
                        <% if (featuredPost.Category) { %><p class="retro-status-line"><a href="<%= BASE_PATH %>/posts/category/<%= featuredPost.Category.slug %>"><%= featuredPost.Category.name %></a></p><% } %>
                        <h2><a href="<%= BASE_PATH %>/posts/<%= featuredPost.slug %>"><%= featuredPost.title %></a></h2>
                        <p class="retro-post-meta">Oleh <%= featuredPost.User ? featuredPost.User.username : 'Admin' %> | <%= featuredPost.createdAt ? new Date(featuredPost.createdAt).toLocaleDateString('id-ID', { month: 'long', day: 'numeric', year: 'numeric' }) : '-' %></p>
                        <p><%= (featuredPost.content || '').replace(/[#*`]/g, '').substring(0, 220) %>…</p>
                        <a class="retro-button" href="<%= BASE_PATH %>/posts/<%= featuredPost.slug %>">Baca selengkapnya</a>
                    </div>
                </div>
            </article>
        <% } %>

        <section class="retro-panel">
            <h2 class="retro-panel-title">📰 <%= (typeof isLandingPage !== 'undefined' && isLandingPage) ? 'Postingan Terbaru' : 'Daftar Postingan' %></h2>
            <div class="retro-panel-body retro-post-list">
                <% if (posts && posts.length > 0) { %>
                    <% posts.slice((typeof isLandingPage !== 'undefined' && isLandingPage) ? 1 : 0).forEach(post => { %>
                        <%- include('../../partials/post-card', { post, BASE_PATH, catColor }) %>
                    <% }) %>
                <% } else { %>
                    <p class="retro-empty">Belum ada artikel yang tersedia.</p>
                <% } %>
            </div>
        </section>
    </section>

    <aside class="retro-utility-column">
        <section class="retro-panel">
            <h3 class="retro-panel-title">🔎 Cari Blog</h3>
            <div class="retro-panel-body">
                <form class="retro-search" action="<%= BASE_PATH %>/search" method="GET">
                    <input class="retro-input" type="search" name="query" placeholder="Kata kunci..." value="<%= typeof q !== 'undefined' ? q : '' %>">
                    <button class="retro-button" type="submit">Cari</button>
                </form>
            </div>
        </section>

        <section class="retro-panel">
            <h3 class="retro-panel-title">🔥 Trending</h3>
            <div class="retro-panel-body">
                <ol class="retro-rank-list">
                    <% var displayTrending = (typeof trendingPosts !== 'undefined' && trendingPosts.length > 0) ? trendingPosts : (posts || []).slice(0, 5); %>
                    <% if (displayTrending.length > 0) { displayTrending.slice(0,5).forEach((post, idx) => { %>
                        <li><a href="<%= BASE_PATH %>/posts/<%= post.slug %>"><%= post.title %></a></li>
                    <% }) } else { %>
                        <li class="retro-muted">Belum ada data.</li>
                    <% } %>
                </ol>
            </div>
        </section>

        <section class="retro-panel">
            <h3 class="retro-panel-title">🏷️ Topik Cepat</h3>
            <div class="retro-panel-body retro-badge-list">
                <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { categories.slice(0, 12).forEach(cat => { %>
                    <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>"><%= cat.name %></a>
                <% }) } else { %><span class="retro-muted">Belum ada kategori.</span><% } %>
            </div>
        </section>
    </aside>
</div>

<%- include('../../partials/footer') %>
