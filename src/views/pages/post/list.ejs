<%- include('../../partials/header', { title: 'Daftar Post - Blog' }) %>
<div class="container retro-list-page">
    <section class="retro-panel">
        <h1 class="retro-panel-title">📰 Daftar Post</h1>
        <div class="retro-panel-body">
            <% if (posts && posts.length > 0) { %>
                <ul class="retro-link-list retro-post-directory">
                    <% posts.forEach(post => { %>
                        <li><a href="<%= typeof BASE_PATH !== 'undefined' ? BASE_PATH : '' %>/posts/<%= post.slug %>"><%= post.title %></a> <span class="retro-muted">oleh <%= post.User ? post.User.username : 'Admin' %></span></li>
                    <% }) %>
                </ul>
            <% } else { %><p class="retro-empty">Belum ada post.</p><% } %>
        </div>
    </section>
</div>
<%- include('../../partials/footer') %>
